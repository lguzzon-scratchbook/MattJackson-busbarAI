config.json
*.env
.env
.env.*

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs / scratch
*.log
/scratch/

# Claude Code session/worktree state (never commit)
/.claude/

# Stray debug/scratch artifacts (never commit)
/rust_out
/scratch_syms.txt

# Python bytecode (bench harness)
__pycache__/
*.pyc
graphify-out/
